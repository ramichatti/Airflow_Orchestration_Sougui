    <queries xmi:id="_nwCVcAdbEfG2FIr1eWEW3Q">
      <query xmi:id="_nwCVcgdbEfG2FIr1eWEW3Q" id="_nwCVcQdbEfG2FIr1eWEW3Q" label="ProduitGroupByReference" value="SELECT&#xD;&#xA;    Ligne_vente_SA.Reference as Reference,&#xD;&#xA;    MAX(Ligne_vente_SA.Description) AS Description,&#xD;&#xA;    MAX(Ligne_vente_SA.PU_HT) AS PU_HT&#xD;&#xA;FROM Ligne_vente_SA&#xD;&#xA;GROUP BY Ligne_vente_SA.Reference;"/>
      <query xmi:id="_7qgREQdhEfG2FIr1eWEW3Q" id="_7qgREAdhEfG2FIr1eWEW3Q" label="EntrepriseDistinct" value="SELECT DISTINCT Entete_vente_SA.Nom as Nom,&#xD;&#xA; Entete_vente_SA.Matricule_fiscal as Matricule_fiscal,&#xD;&#xA; Entete_vente_SA.Adresse as Adresse&#xD;&#xA;FROM Entete_vente_SA"/>
      <query xmi:id="_sI-ncAdiEfG2FIr1eWEW3Q" id="_sI-AYAdiEfG2FIr1eWEW3Q" label="InnerJoin_EnteteLigneB2B" value="SELECT &#xD;&#xA;    l.Num_facture,&#xD;&#xA;    l.Reference,&#xD;&#xA;    l.Description,&#xD;&#xA;    l.PU_HT,&#xD;&#xA;    l.Quantite,&#xD;&#xA;    l.Prix_Total_HT,&#xD;&#xA;    e.Date,&#xD;&#xA;    e.Nom,&#xD;&#xA;    e.Matricule_fiscal,&#xD;&#xA;    e.Adresse,&#xD;&#xA;    e.Montant_Total_HT,&#xD;&#xA;    e.TVA,&#xD;&#xA;    e.Timbre,&#xD;&#xA;    e.Total_TTC,&#xD;&#xA;    e.Type&#xD;&#xA;FROM [Sougui_SA].[dbo].[Ligne_vente_SA] l&#xD;&#xA;INNER JOIN [Sougui_SA].[dbo].[Entete_vente_SA] e&#xD;&#xA;    ON l.Num_facture = e.Num_facture;&#xD;&#xA;"/>
      <query xmi:id="_QzZAIQtkEfGiQqClFW8Kuw" id="_QzZAIAtkEfGiQqClFW8Kuw" label="FullJoin_ProduitSougui" value="WITH AllData AS (&#xD;&#xA;    SELECT &#xD;&#xA;        Reference,&#xD;&#xA;        Description,&#xD;&#xA;        PU_HT,&#xD;&#xA;        'VENTE' AS Source&#xD;&#xA;    FROM [Sougui_SA].[dbo].[Ligne_vente_SA]&#xD;&#xA;&#xD;&#xA;    UNION ALL&#xD;&#xA;&#xD;&#xA;    SELECT &#xD;&#xA;        Reference,&#xD;&#xA;        Description,&#xD;&#xA;        NULL AS PU_HT,&#xD;&#xA;        'BL' AS Source&#xD;&#xA;    FROM [Sougui_SA].[dbo].[Ligne_bl_SA]&#xD;&#xA;),&#xD;&#xA;&#xD;&#xA;RankedData AS (&#xD;&#xA;    SELECT *,&#xD;&#xA;           ROW_NUMBER() OVER (&#xD;&#xA;               PARTITION BY Reference &#xD;&#xA;               ORDER BY LEN(ISNULL(Description,'')) DESC&#xD;&#xA;           ) AS rn&#xD;&#xA;    FROM AllData&#xD;&#xA;)&#xD;&#xA;&#xD;&#xA;SELECT &#xD;&#xA;    Reference,&#xD;&#xA;    Description,&#xD;&#xA;    PU_HT,&#xD;&#xA;    Source&#xD;&#xA;FROM RankedData&#xD;&#xA;WHERE rn = 1;&#xD;&#xA;"/>
      <query xmi:id="_opExARbXEfGfmK9uAACxBQ" id="_opExABbXEfGfmK9uAACxBQ" label="FactLivraison" value="SELECT &#xD;&#xA;    e.Num_document,&#xD;&#xA;    e.Date,&#xD;&#xA;    e.Nom,&#xD;&#xA;    e.Matricule_fiscal,&#xD;&#xA;    e.Adresse,&#xD;&#xA;    e.Latitude,&#xD;&#xA;    e.Longitude,&#xD;&#xA;    e.Type,&#xD;&#xA;    l.Reference,&#xD;&#xA;    l.Description,&#xD;&#xA;    l.Quantite&#xD;&#xA;FROM dbo.Entete_bl_SA e&#xD;&#xA;INNER JOIN dbo.Ligne_bl_SA l ON e.Num_document = l.Num_document"/>
      <query xmi:id="_e_N50RbiEfGfmK9uAACxBQ" id="_e_N50BbiEfGfmK9uAACxBQ" label="GroupByFournisseurMF" value="SELECT &#xD;&#xA;    MAX(fournisseur) AS fournisseur,&#xD;&#xA;    matricule_fiscal,&#xD;&#xA;    LEFT(MAX(telephones), &#xD;&#xA;         CHARINDEX(',', MAX(telephones) + ',') - 1) AS telephone&#xD;&#xA;FROM Sougui_SA.dbo.Entete_Achat_SA&#xD;&#xA;GROUP BY matricule_fiscal;"/>
      <query xmi:id="_qfHEkRbiEfGfmK9uAACxBQ" id="_qfHEkBbiEfGfmK9uAACxBQ" label="GroupByProduitByReference" value="SELECT &#xD;&#xA;    reference as Reference,&#xD;&#xA;    MAX(description) AS Description,&#xD;&#xA;    MAX(prix_unitaire) AS PU_HT&#xD;&#xA;FROM Sougui_SA.dbo.Ligne_achat_SA&#xD;&#xA;GROUP BY reference;"/>
    </queries>
