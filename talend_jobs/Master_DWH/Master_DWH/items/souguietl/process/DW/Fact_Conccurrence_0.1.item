    <elementParameter field="MEMO_SQL" name="QUERY" value="&quot;SELECT &#xD;&#xA;    s.Reference,&#xD;&#xA;    MAX(i.Original_Iley_Name) AS Original_Iley_Name,&#xD;&#xA;    MAX(i.Original_Iley_Category) AS Original_Iley_Category,&#xD;&#xA;    MAX(i.Iley_Price) AS Iley_Price,&#xD;&#xA;    MAX(k.Original_Kalys_Name) AS Original_Kalys_Name,&#xD;&#xA;    MAX(k.Original_Kalys_Category) AS Original_Kalys_Category,&#xD;&#xA;    MAX(k.Kalys_Price) AS Kalys_Price,&#xD;&#xA;    MAX(s.Nom) AS Nom,&#xD;&#xA;    MAX(s.Forced_Category) AS Forced_Category,&#xD;&#xA;    MAX(s.Prix_Unitaire_TND) AS Prix_Unitaire_TND,&#xD;&#xA;    MAX(s.Source) AS Sougui_Source&#xD;&#xA;FROM [Sougui_SA].[dbo].[Produits_Sougui_SA] s&#xD;&#xA;INNER JOIN [Sougui_SA].[dbo].[Produits_Ileyckom_SA] i&#xD;&#xA;    ON s.Reference = i.Sougui_Reference&#xD;&#xA;INNER JOIN [Sougui_SA].[dbo].[Produits_Kalys_SA] k&#xD;&#xA;    ON s.Reference = k.Sougui_Reference&#xD;&#xA;GROUP BY s.Reference;&quot;"/>
